            "hash": "07604b07f46ffd21b5c780217e428c583f469878ea6a872dc55d7220a22d2292"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/aczgelg4rgzsl4j4jaw4s5f6bgpa_147.0.7727.0/147.0.7727.0_chrome_installer_uncompressed.exe#/dl.7z",
