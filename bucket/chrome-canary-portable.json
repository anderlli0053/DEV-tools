        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acil4znsr7jbavmlvmftdv4qc3mq_151.0.7903.0/151.0.7903.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "93b44af504fb147040fec348d780425a66ba6ed2d24fe369f6604ce1dc5fef7d"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adsxbpzbgxe4oyvdravfmcehfeta_151.0.7903.0/151.0.7903.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "4769f00028ed949eee095d2771a68ccee23fcf23da43577084998d267b4da729"
