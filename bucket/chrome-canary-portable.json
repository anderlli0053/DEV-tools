            "hash": "3da1f91eb7b2f36d51afbc548ec65e1f14729fba631bb7ec1f399f98811447ad"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ac5kmikz5e5a37nxv7chkmvfr5qa_152.0.7948.0/152.0.7948.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "8227161407befbc4cf46584b67428842c6a9396804f3b2a16d2cf83781b4865c"
