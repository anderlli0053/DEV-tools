            "hash": "5dcdb7a825e1fdc4e65a6056fa946f23292c4db8fdf66cbcc43b8e4777451cb8"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/hm6k6c466x37fyjrug64pu57fi_148.0.7778.0/148.0.7778.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "974d0b0788548802e099cce2ed5dbc1033f364c217278bb7da289d8146aa964c"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/k3tskf2gyrxkrdyyoob7pqkcpu_148.0.7778.0/148.0.7778.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "47bb2dc7efdf0ba35447e0ee845483ee72c505a568f6d4cb902eb72e7c46e810"
