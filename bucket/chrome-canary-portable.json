            "hash": "03c31bb59929f98fa84bd2d63db4c14f60051659f8d01939d05546ff968a7eb3"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/cnkryocodqnl7f6f2fp2tvcfau_148.0.7730.0/148.0.7730.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "346617650fefac5261e962106e0fd0fe12060cf277f0672214157afa6cea9049"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acmbydfx7bmnvqdlriwiaw6ewyea_148.0.7730.0/148.0.7730.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "2764de242e9f37a3b38405ad8754361213bd1ffae303953d5b545f180a65fda7"
