        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ollo3wsnnzfpcj6wxkfmclttou_148.0.7761.0/148.0.7761.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "63a15b610e1cbc92e9a968bead5beb930702af859597dc14637232deb63cd8fb"
