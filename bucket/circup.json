{
    "version": "3.0.4",
    "description": "CircuitPython library updater. ",
    "homepage": "https://github.com/adafruit/circup",
    "license": "MIT",
    "url": "https://ghproxy.com/https://github.com/adafruit/circup/archive/refs/tags/3.0.4.tar.gz",
    "hash": "94176d686473f905c7e64a2ef0a5a52e7194e02b7b8442b4ba7c941f10d589db",
    "depends": "python",
    "installer": {
        "script": [
            "Push-Location \"$dir\"",
            "python -m venv circup",
            ".\\circup\\Scripts\\activate",
            "try {",
            "    python -m pip install wheel",
            "    python -m pip install circup",
            "}",
            "finally {",
            "    Remove-Item \"circup-$version\" -Recurse",
            "    deactivate",
            "    Pop-Location",
            "}"
        ]
    },
    "bin": "circup\\Scripts\\circup.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://ghproxy.com/https://github.com/adafruit/circup/archive/refs/tags/$version.tar.gz"
    }
}
