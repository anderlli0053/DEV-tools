{
    "version": "20260710.14",
    "description": "Liero clone / Worms realtime / 2D shooter",
    "homepage": "https://openlierox.net/",
    "license": "LGPL",
    "url": "https://github.com/openlierox/openlierox/releases/download/20260710.14/openlierox-20260710.14-windows.zip",
    "hash": "2ba53b152d98d492a6612ddaac1bb7b524b051c26a943f6330925ac98c46bf4e",
    "pre_install": [
        "Write-Host 'Flattening directory structure...' -ForegroundColor Cyan",
        "$folders = Get-ChildItem \"$dir\" -Directory",
        "$totalFolders = $folders.Count",
        "$counter = 0",
        "foreach ($folder in $folders) {",
        "    $counter++",
        "    $files = Get-ChildItem $folder.FullName -Recurse",
        "    $totalFiles = $files.Count",
        "    $fileCounter = 0",
        "    Write-Host \"  Processing $($folder.Name)... ($counter/$totalFolders) - $totalFiles files\" -ForegroundColor Yellow",
        "    foreach ($file in $files) {",
        "        $fileCounter++",
        "        Write-Host \"    Moving: $($file.Name)... ($fileCounter/$totalFiles)\" -ForegroundColor Gray",
        "        Move-Item $file.FullName -Destination \"$dir\" -Force -ErrorAction SilentlyContinue",
        "    }",
        "    Remove-Item $folder.FullName -Recurse -Force",
        "}",
        "Write-Host 'Directory flattening complete!' -ForegroundColor Green"
    ],
    "bin": "openlierox.exe",
    "shortcuts": [
        [
            "openlierox.exe",
            "OpenLieroX"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/openlierox/openlierox/releases/latest",
        "json": "tag_name",
        "re": "([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/openlierox/openlierox/releases/download/$version/openlierox-$version-windows.zip"
    }
}
