    },
    "installer": {
        "script": [
            "$subfolder = Get-ChildItem \"$dir\" -Directory | Select-Object -First 1",
            "if ($subfolder) {",
            "    Move-Item \"$subfolder\\*\" \"$dir\" -Force",
            "    Remove-Item \"$subfolder\" -Force",
            "}"
        ]
    },
    "bin": [
        "ppic.exe",
        "passoc.exe"
    ],
    "shortcuts": [
        [
            "ppic.exe",
            "Pineapple Pictures"
        ],
        [
            "passoc.exe",
            "Pineapple Pictures Association Tool"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BLumia/pineapple-pictures/releases/download/$version/pineapple-pictures-$version-Windows-msvc2022-x86_64.zip",
                "hash": {
                    "mode": "download"
                }
            }
        }
    }
