    "homepage": "https://github.com/ArmCord/ArmCord",
    "license": "OSL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/ArmCord/ArmCord/releases/download/v1.2.3/ArmCord.Setup.1.2.3.exe#/dl.7z",
            "hash": "sha512:79320c6c69fb9ea8db1666da524dcf22b9d63eb5e0ddda7592f7824e96ef6b2d77d0927da712968bf410ad43af3e80cc852544f354c1d7e7233227f546a67fb1",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
