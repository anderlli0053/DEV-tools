        },
        "32bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.92.144/BraveBrowserStandaloneSilentSetup32.exe#/setup.exe",
            "hash": "3e559f7cc2983fcd7417bd79f07dd63526c4c00b27fecec3949a759260aa00ac"
